@model IEnumerable<Enrich.Web.ViewModels.UserListViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

@section Styles {
    <link rel="stylesheet" href="~/css/administration.css" asp-append-version="true" />
}

<div class="container-fluid pt-4 administration-page admin-users-page">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card admin-card">
        <div class="card-header admin-card-header">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                <h4 class="fw-semibold mb-0">Administration: Manage Users</h4>
                <span class="badge admin-total-badge">Total: @(Model == null ? 0 : Model.Count())</span>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 admin-table">
                    <thead>
                        <tr>
                            <th class="ps-4 py-3 text-muted fw-semibold">Username</th>
                            <th class="py-3 text-muted fw-semibold">Email</th>
                            <th class="py-3 text-muted fw-semibold">Role & Status</th>
                            <th class="text-end pe-4 py-3 text-muted fw-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model ?? System.Linq.Enumerable.Empty<Enrich.Web.ViewModels.UserListViewModel>())
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="admin-avatar">
                                            @((!string.IsNullOrEmpty(user?.Username) && user.Username.Length > 0) ? user.Username.Substring(0, 1).ToUpper() : "?")
                                        </div>
                                        <span class="fw-medium">@((user?.Username) ?? string.Empty)</span>
                                    </div>
                                </td>
                                <td>@(user?.Email ?? string.Empty)</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <span class="badge admin-pill admin-role-badge">
                                            @((user?.Role) ?? string.Empty)
                                        </span>
                                        @if (user != null && user.IsLockedOut)
                                        {
                                            <span class="badge admin-pill admin-status-badge admin-status-locked">Locked</span>
                                        }
                                        else
                                        {
                                            <span class="badge admin-pill admin-status-badge admin-status-active">Active</span>
                                        }
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-inline-flex flex-wrap gap-2">
                                        <button class="btn btn-sm admin-action-btn">Edit</button>

                                        @if (user != null && user.IsLockedOut)
                                        {
                                            <a asp-action="Restore" asp-route-id="@user?.Id" asp-route-username="@user?.Username" class="btn btn-sm admin-action-btn">Restore</a>
                                        }
                                        else
                                        {
                                            <a asp-action="Restrict" asp-route-id="@user?.Id" asp-route-username="@user?.Username" class="btn btn-sm btn-action-danger admin-action-btn">Restrict</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/administration.js" asp-append-version="true"></script>
}
