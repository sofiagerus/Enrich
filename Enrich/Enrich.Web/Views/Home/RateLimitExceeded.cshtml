@{
    ViewData["Title"] = "Too Many Requests";
    Layout = null;

    int statusCode = 429;
    string errorTitle = "Too Many Requests";
    string errorDesc = "You have exceeded the request limit. Please wait a minute and try again.";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@errorTitle - Enrich</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        body {
            font-family: 'Open Sans', sans-serif;
        }
    </style>
</head>
<body class="bg-success text-dark d-flex flex-column justify-content-center" style="--bs-bg-opacity: 0.08; min-height: 100vh; padding: 0 15vw;">
    <div style="max-width: 600px;">
        <h1 class="fw-normal m-0" style="font-size: 5rem; line-height: 1.1;">@statusCode</h1>
        <h2 class="display-5 fw-normal m-0 mb-4 lh-base">@errorTitle</h2>
        <p class="fs-5 text-dark m-0 mb-5">@errorDesc</p>

        <a href="/" class="btn btn-success px-4 py-2 rounded-3 shadow-sm text-decoration-none">
            Back to Home
        </a>
    </div>
</body>
</html>