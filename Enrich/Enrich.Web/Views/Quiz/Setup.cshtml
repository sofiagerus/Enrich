@model Enrich.BLL.DTOs.QuizSetupDTO
@{
    ViewData["Title"] = "Quiz Setup";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
    var categories = ViewBag.Categories as IEnumerable<string> ?? new List<string>();
    var partsOfSpeech = ViewBag.PartsOfSpeech as IEnumerable<string> ?? new List<string>();
}

@section Styles {
    <link rel="stylesheet" href="~/css/quiz-setup.min.css" asp-append-version="true" />
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" asp-controller="Home" class="text-dark text-decoration-none fs-5">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="fw-semibold fs-4 mb-0">Quiz Setup</h1>
</div>

<div class="card border border-light-subtle rounded-4 mb-4" style="max-width: 640px;">
    <div class="card-body p-4 p-md-5">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger rounded-4 small mb-4 border-0" style="background-color: #fff5f5; color: #dc3545;" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i> @TempData["Error"]
            </div>
        }

        <form asp-action="Start" method="post">
            
            @* Category *@
            <div class="mb-4">
                <label asp-for="Category" class="form-label fw-medium text-dark small mb-2">Category</label>
                <select asp-for="Category" class="form-select rounded-4 py-2 border-light-subtle" style="box-shadow: none;">
                    <option value="Any">Any Category</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>

            @* Part of Speech *@
            <div class="mb-4">
                <label asp-for="PartOfSpeech" class="form-label fw-medium text-dark small mb-2">Part of Speech</label>
                <select asp-for="PartOfSpeech" class="form-select rounded-4 py-2 border-light-subtle" style="box-shadow: none;">
                    <option value="Any">Any Part of Speech</option>
                    @foreach (var pos in partsOfSpeech)
                    {
                        <option value="@pos">@pos</option>
                    }
                </select>
            </div>

            @* Difficulty Levels *@
            <div class="row mb-4 g-4">
                <div class="col-md-6">
                    <label asp-for="MinDifficulty" class="form-label fw-medium text-dark small mb-2">Difficulty (Min)</label>
                    <select asp-for="MinDifficulty" class="form-select rounded-4 py-2 border-light-subtle" style="box-shadow: none;">
                        <option value="0">A1</option>
                        <option value="1">A2</option>
                        <option value="2">B1</option>
                        <option value="3">B2</option>
                        <option value="4">C1</option>
                        <option value="5">C2</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="MaxDifficulty" class="form-label fw-medium text-dark small mb-2">Difficulty (Max)</label>
                    <select asp-for="MaxDifficulty" class="form-select rounded-4 py-2 border-light-subtle" style="box-shadow: none;">
                        <option value="0">A1</option>
                        <option value="1">A2</option>
                        <option value="2">B1</option>
                        <option value="3">B2</option>
                        <option value="4">C1</option>
                        <option value="5" selected>C2</option>
                    </select>
                </div>
            </div>

            @* Number of Words *@
            <div class="mb-5">
                <label asp-for="WordCount" class="form-label fw-medium text-dark small mb-2">Number of Words</label>
                <input type="number" asp-for="WordCount" class="form-control rounded-4 py-2 border-light-subtle" min="1" max="50" value="10" style="box-shadow: none;" />
                <span asp-validation-for="WordCount" class="text-danger small d-block mt-1"></span>
            </div>

            @* Ęíîďęč ôîđěč (ÂÍČÇÓ) *@
            <div class="d-flex gap-3 justify-content-start">
                <button type="submit" class="btn btn-success btn-action-success rounded-pill px-4 py-2 fw-medium d-flex align-items-center gap-2" style="background-color: #1a7b54; border-color: #1a7b54; transition: all 0.2s;">
                    <i class="bi bi-play-fill fs-5"></i> Start Quiz Session
                </button>
                <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-medium">
                    Cancel
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}