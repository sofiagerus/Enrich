@model Enrich.Web.ViewModels.EditWordViewModel

@{
    ViewData["Title"] = "Edit Word";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/word-edit.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="MyWords" asp-controller="Word"
           class="btn btn-light rounded-circle me-3 d-flex align-items-center justify-content-center"
           style="width: 40px; height: 40px;"
           id="btn-back-mywords">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="h3 mb-0 fw-bold">Edit Word</h1>
    </div>

    <div class="card word-form-card mx-auto" style="max-width: 640px;">
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger rounded-3 small mb-4" role="alert">
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="Edit" asp-controller="Word" method="post" id="edit-word-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="WordId" />

            <div class="mb-4">
                <label asp-for="Term" class="form-label">
                    Word <span class="text-danger ms-1">*</span>
                </label>
                <input asp-for="Term"
                       class="form-control form-control-custom w-100"
                       placeholder="e.g. Serendipity" />
                <span asp-validation-for="Term" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Translation" class="form-label">Translation</label>
                <input asp-for="Translation"
                       class="form-control form-control-custom w-100"
                       placeholder="e.g. Щасливий випадок" />
                <span asp-validation-for="Translation" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Meaning" class="form-label">Meaning</label>
                <textarea asp-for="Meaning"
                          class="form-control form-control-custom w-100"
                          rows="2"
                          placeholder="Short definition"></textarea>
                <span asp-validation-for="Meaning" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Example" class="form-label">Example</label>
                <textarea asp-for="Example"
                          class="form-control form-control-custom w-100"
                          rows="2"
                          placeholder="Sentence using the word"></textarea>
                <span asp-validation-for="Example" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="d-flex gap-3 justify-content-center mt-5 pt-4 border-top">
                <button type="submit" class="btn-action-success">
                    <i class="bi bi-save me-2"></i> Save Changes
                </button>
                <a asp-action="MyWords" asp-controller="Word" class="btn-action-outline-success">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/word-edit.js" asp-append-version="true"></script>
}