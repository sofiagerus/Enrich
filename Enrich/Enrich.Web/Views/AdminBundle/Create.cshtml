@model Enrich.Web.ViewModels.CreateBundleViewModel
@{
    ViewData["Title"] = "Create System Collection";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-bundle-create.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-light rounded-circle me-3 back-button" aria-label="Back">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="h3 mb-0 fw-bold">Create System Collection</h1>
    </div>

    <div class="card card-panel shadow-sm border-0 rounded-4">
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger" role="alert">
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form method="post" class="bundle-create-form" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label">Collection Title</label>
                        <input asp-for="Title" class="form-control w-100 rounded-4 form-control-custom" placeholder="Your collection title">
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control w-100 rounded-4 form-control-custom" placeholder="Describe the content and purpose of your collection"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                        <div class="mt-1">
                            <small class="text-muted description-counter">
                                <span id="description-count">0</span> / 1000 characters
                            </small>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Categories</label>
                        <div class="dropdown custom-dropdown-container" id="categories-dropdown-container" data-bs-auto-close="outside">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="selected-items-display text-muted">Select categories...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items" style="max-height: 300px; overflow-y: auto;">
                                </div>
                            </div>
                        </div>
                        <div id="category-ids-hidden"></div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Words</label>
                        <div class="dropdown custom-dropdown-container" id="words-dropdown-container" data-bs-auto-close="outside">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="selected-items-display text-muted">Select words...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items" style="max-height: 300px; overflow-y: auto;">
                                </div>
                            </div>
                        </div>
                        <div id="word-ids-hidden"></div>
                    </div>

                    <div class="mb-0">
                        <label class="form-label">Difficulty Levels</label>
                        <div class="dropdown custom-dropdown-container" id="levels-dropdown-container" data-bs-auto-close="outside">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="selected-items-display text-muted">Select levels...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items" style="max-height: 250px; overflow-y: auto;">
                                </div>
                            </div>
                        </div>
                        <div id="level-ids-hidden"></div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <label class="form-label">Cover Image</label>
                    <div class="image-upload-box w-100 rounded-4" id="image-upload-box">
                        <div id="upload-placeholder">
                            <i class="bi bi-folder"></i>
                            <p class="text-muted mb-3 fw-medium">Click to upload cover image</p>
                            <button type="button" class="image-upload-btn rounded-4" id="upload-image-btn">Upload Image</button>
                        </div>
                        <div id="image-preview-container" style="display: none; width: 100%; height: 100%;">
                            <img id="image-preview" class="image-preview rounded-4" alt="Preview">
                        </div>
                    </div>
                    <input type="file" id="file-input" style="display:none;" accept="image/*">
                    <input type="hidden" asp-for="ImageUrl" id="ImageUrl">
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center mt-5 pt-4 border-top">
                <button type="submit" class="btn-action-success rounded-4">
                    <i class="bi bi-plus-lg me-2"></i> Create Collection
                </button>
                <a asp-action="Index" class="btn-action-outline-success rounded-4">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-bundle-create.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            AdminBundleCreate.init({
                selectedCategoryIds: @Html.Raw(Json.Serialize(Model.CategoryIds ?? new List<int>())),
                selectedWordIds: @Html.Raw(Json.Serialize(Model.WordIds ?? new List<int>())),
                selectedLevels: @Html.Raw(Json.Serialize(Model.DifficultyLevels ?? new List<string>())),
                allWords: @Html.Raw(Json.Serialize(Model.Words ?? new List<Enrich.Web.ViewModels.WordItemViewModel>())),
                availableLevels: @Html.Raw(Json.Serialize(Model.AvailableLevels ?? new List<string>()))
            });
        });
    </script>
}
