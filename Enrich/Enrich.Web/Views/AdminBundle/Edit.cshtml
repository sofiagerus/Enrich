@model Enrich.Web.ViewModels.EditBundleViewModel
@{
    ViewData["Title"] = "Edit Collection";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-bundle-edit.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="@(Model.IsSystem ? "Index" : "Community")" class="btn btn-light rounded-circle me-3 back-button" aria-label="Back">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="h3 mb-0 fw-bold">Edit @(Model.IsSystem ? "System" : "Community") Bundle</h1>
    </div>

    <div class="card card-panel shadow-sm border-0 rounded-4">
        @if (!Model.IsSystem)
        {
            <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-4 status-strip">
                <p class="mb-0 fw-medium text-dark">Status:</p>
                <span class="status-badge-info status-@Model.Status.ToString().ToLower() px-3 py-1 rounded-pill small fw-semibold">
                    @Model.Status
                </span>
            </div>
        }

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger" role="alert">
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="Edit" method="post" class="bundle-edit-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="IsSystem" />
            <input type="hidden" asp-for="Status" />

            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label">Collection Title</label>
                        <input asp-for="Title" class="form-control w-100 rounded-4 form-control-custom" placeholder="Your collection title">
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control w-100 rounded-4 form-control-custom" placeholder="Describe the content and purpose of your collection"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                        <div class="mt-1">
                            <small class="text-muted description-counter">
                                <span id="description-count">0</span> / @Enrich.BLL.Constants.BundleConstants.DescriptionMaxLength characters
                            </small>
                        </div>
                    </div>

                    @if (!Model.IsSystem)
                    {
                        <div class="mb-4">
                            <label class="form-label">Status</label>
                            <div class="dropdown custom-dropdown-container" id="statusDropdownContainer" data-bs-auto-close="outside">
                                <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="selected-items-display text-muted">Select status...</span>
                                    <i class="bi bi-chevron-down opacity-50 small"></i>
                                </button>
                                <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                    <div class="dropdown-list-items" style="max-height: 220px; overflow-y: auto;">
                                        @foreach (var status in Html.GetEnumSelectList<Enrich.DAL.Entities.Enums.BundleStatus>())
                                        {
                                            var isSelectedStatus = string.Equals(status.Value, ((int)Model.Status).ToString(), StringComparison.OrdinalIgnoreCase);
                                            <div class="dropdown-item-custom @(isSelectedStatus ? "selected" : "")" data-value="@status.Value" data-label="@status.Text">
                                                <span>@status.Text</span>
                                                <i class="bi bi-check2 opacity-0"></i>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mb-4">
                        <label class="form-label">Categories</label>
                        <div class="dropdown custom-dropdown-container" id="categories-dropdown-container" data-bs-auto-close="outside">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="selected-items-display text-muted">Select categories...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items" style="max-height: 300px; overflow-y: auto;">
                                    @foreach (var cat in Model.Categories)
                                    {
                                        var isSelectedCat = Model.CategoryIds != null && Model.CategoryIds.Contains(cat.Id);
                                        <div class="dropdown-item-custom @(isSelectedCat ? "selected" : "")" data-value="@cat.Id" data-label="@cat.Name">
                                            <span>@cat.Name</span>
                                            <i class="bi bi-check2 opacity-0"></i>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div id="category-ids-hidden"></div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Words</label>
                        <div class="dropdown custom-dropdown-container" id="words-dropdown-container" data-bs-auto-close="outside">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="selected-items-display text-muted">Select words...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items" style="max-height: 300px; overflow-y: auto;">
                                    @foreach (var word in Model.Words)
                                    {
                                        var isSelectedWord = Model.WordIds != null && Model.WordIds.Contains(word.Id);
                                        <div class="dropdown-item-custom @(isSelectedWord ? "selected" : "")" data-value="@word.Id" data-label="@word.Term">
                                            <span>@word.Term</span>
                                            <i class="bi bi-check2 opacity-0"></i>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div id="word-ids-hidden"></div>
                    </div>

                    <div class="mb-0">
                        <label class="form-label">Difficulty Levels</label>
                        <div class="dropdown custom-dropdown-container" id="levels-dropdown-container" data-bs-auto-close="outside">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="selected-items-display text-muted">Select levels...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items" style="max-height: 250px; overflow-y: auto;">
                                    @foreach (var level in Model.AvailableLevels)
                                    {
                                        var isSelectedLevel = Model.DifficultyLevels != null && Model.DifficultyLevels.Contains(level);
                                        <div class="dropdown-item-custom @(isSelectedLevel ? "selected" : "")" data-value="@level" data-label="@level">
                                            <span>@level</span>
                                            <i class="bi bi-check2 opacity-0"></i>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div id="level-ids-hidden"></div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <label class="form-label">Cover Image</label>
                    <div class="image-upload-box w-100 rounded-4" id="image-upload-box">
                        <div id="upload-placeholder" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "" : "display: none;")">
                            <i class="bi bi-folder" style="font-size: 2.5rem; color: var(--enrich-text-muted);"></i>
                            <p class="text-muted mb-3 fw-medium mt-2">Click to upload cover image</p>
                            <button type="button" class="image-upload-btn rounded-4" id="upload-image-btn">Upload Image</button>
                        </div>
                        <div id="image-preview-container" style="@(!string.IsNullOrEmpty(Model.ImageUrl) ? "display: block; width: 100%; height: 100%;" : "display: none; width: 100%; height: 100%;")">
                            <img id="image-preview" src="@Model.ImageUrl" class="image-preview rounded-4" alt="Preview">
                        </div>
                    </div>
                    <div id="change-image-btn-container" class="mt-3 text-center" style="@(!string.IsNullOrEmpty(Model.ImageUrl) ? "display: block;" : "display: none;")">
                        <button type="button" class="btn-change-image" id="change-image-btn">
                            <i class="bi bi-pencil me-2"></i> Change Image
                        </button>
                    </div>
                    <input type="file" id="file-input" style="display:none;" accept="image/*">
                    <input type="hidden" asp-for="ImageUrl" id="ImageUrl">
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center mt-5 pt-4 border-top flex-wrap">
                <button type="submit" class="btn-action-success rounded-4">
                    <i class="bi bi-save me-2"></i> Save Changes
                </button>
                <a asp-action="@(Model.IsSystem ? "Index" : "Community")" class="btn-action-outline-success rounded-4">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-bundle-edit.js" asp-append-version="true"></script>
}
