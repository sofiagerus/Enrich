@model Enrich.Web.ViewModels.EditBundleViewModel
@{
    ViewData["Title"] = "Edit System Collection";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-3 d-flex align-items-center gap-1 text-decoration-none">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <h1 class="fw-semibold fs-4 mb-0">Edit System Collection: @Model.Title</h1>
</div>

<div class="card border-0 shadow-sm rounded-4 mx-auto" style="max-width: 800px;">
    <div class="card-body p-4">
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger rounded-3 small mb-4" role="alert">
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-medium mb-1">
                    Title <span class="text-danger ms-1">*</span>
                </label>
                <input asp-for="Title" class="form-control border-1 shadow-sm rounded-4 py-2" placeholder="Enter collection title" />
                <span asp-validation-for="Title" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-medium mb-1">Description</label>
                <textarea asp-for="Description" class="form-control border-1 shadow-sm rounded-4 py-2" rows="3" placeholder="Enter description"></textarea>
                <span asp-validation-for="Description" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label fw-medium mb-1">Image URL</label>
                <input asp-for="ImageUrl" class="form-control border-1 shadow-sm rounded-4 py-2" placeholder="https://..." />
                <span asp-validation-for="ImageUrl" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DifficultyLevels" class="form-label fw-medium mb-1">Difficulty Levels</label>
                <select asp-for="DifficultyLevels" class="form-select border-1 shadow-sm rounded-4 py-2" multiple size="3">
                    @foreach (var level in Model.AvailableLevels)
                    {
                        <option value="@level">@level</option>
                    }
                </select>
                <span asp-validation-for="DifficultyLevels" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryIds" class="form-label fw-medium mb-1">Categories</label>
                <select asp-for="CategoryIds" class="form-select border-1 shadow-sm rounded-4 py-2" multiple size="4">
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryIds" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="mb-4">
                <label asp-for="WordIds" class="form-label fw-medium mb-1">Words</label>
                <select asp-for="WordIds" class="form-select border-1 shadow-sm rounded-4 py-2" multiple size="5">
                    @foreach (var word in Model.Words)
                    {
                        <option value="@word.Id">@word.Term - @word.Translation</option>
                    }
                </select>
                <span asp-validation-for="WordIds" class="text-danger small d-block mt-1"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary rounded-4 px-5 fw-medium shadow-sm">Save Changes</button>
                <a asp-action="Index" class="btn btn-outline-secondary rounded-4 px-4 shadow-sm">Cancel</a>
            </div>
        </form>
    </div>
</div>