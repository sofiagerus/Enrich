@model Enrich.BLL.DTOs.PagedResult<Enrich.BLL.DTOs.SystemBundleDTO>
@{
    ViewData["Title"] = "Manage System Bundles";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-word.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-semibold fs-4 mb-0">Manage System Collections</h1>
    <a asp-action="Create" class="btn-action-success">
        <i class="bi bi-plus-circle me-2"></i> Add Collection
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show admin-alert mb-4" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show admin-alert mb-4" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card admin-card mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <form method="get" class="row g-3 align-items-end" id="filter-form">
            <div class="col-md-9">
                <label for="search" class="form-label small text-muted mb-1 fw-medium">Search</label>
                <input type="text" id="search" name="search" value="@ViewBag.SearchTerm" class="form-control form-control-custom" placeholder="Search collections..." onkeyup="debounceSearch()" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn-action-outline-success w-100" style="padding-top:0.6rem; padding-bottom:0.6rem;">
                     <i class="bi bi-funnel me-1"></i> Filter
                </button>
            </div>
        </form>
    </div>

    <div class="card-body p-0 mt-4 border-top">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0">Title</th>
                        <th class="py-3 border-0">Words Count</th>
                        <th class="py-3 border-0">Categories</th>
                        <th class="pe-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="4" class="py-4 text-center text-muted">No system collections found.</td>
                        </tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-medium">@item.Title</td>
                            <td class="py-3 text-muted">@item.WordCount</td>
                            <td class="py-3 text-muted">@(string.Join(", ", item.Categories) ?? "-")</td>
                            <td class="pe-4 py-3 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm border text-secondary btn-icon-action bg-white">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="delete-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm border text-danger btn-icon-action bg-white" style="border-color: #f5c2c7 !important;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-word.js" asp-append-version="true"></script>
    <script src="~/js/admin-bundles.js" asp-append-version="true"></script>
}