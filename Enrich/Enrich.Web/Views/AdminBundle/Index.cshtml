@model Enrich.BLL.DTOs.PagedResult<Enrich.BLL.DTOs.SystemBundleDTO>
@{
    ViewData["Title"] = "Manage System Bundles";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-semibold fs-4 mb-0">Manage System Collections</h1>
    <a asp-action="Create" class="btn btn-success rounded-4 px-4 shadow-sm">
        <i class="bi bi-plus-circle me-2"></i> Add Collection
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success rounded-4 shadow-sm mb-4">
        <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger rounded-4 shadow-sm mb-4">
        <i class="bi bi-exclamation-octagon me-2"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-9">
                <label for="search" class="form-label small text-muted mb-1">Search</label>
                <input type="text" id="search" name="search" value="@ViewBag.SearchTerm" class="form-control border-1 shadow-sm rounded-4 py-2" placeholder="Search collections..." />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-secondary border-1 shadow-sm rounded-4 py-2 w-100">
                     Search
                </button>
            </div>
        </form>
    </div>

    <div class="card-body p-0 mt-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0">Title</th>
                        <th class="py-3 border-0">Words Count</th>
                        <th class="py-3 border-0">Categories</th>
                        <th class="pe-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="4" class="py-4 text-center text-muted">No system collections found.</td>
                        </tr>
                    }
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-medium">@item.Title</td>
                            <td class="py-3 text-muted">@item.WordCount</td>
                            <td class="py-3 text-muted">@(string.Join(", ", item.Categories) ?? "-")</td>
                            <td class="pe-4 py-3 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-3">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this collection?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>