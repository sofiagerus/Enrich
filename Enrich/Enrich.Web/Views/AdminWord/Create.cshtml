@model Enrich.Web.ViewModels.CreateWordViewModel
@{
    ViewData["Title"] = "Create System Word";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-word-create.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-light rounded-circle me-3 back-button" aria-label="Back">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="h3 mb-0 fw-bold">Create System Word</h1>
    </div>

    <div class="card card-panel shadow-sm border-0 rounded-4 word-create-card">
        <div class="card-body p-4">
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger" role="alert">
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <form method="post" asp-action="Create" class="word-create-form">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label asp-for="Term" class="form-label">Term <span class="text-danger ms-1">*</span></label>
                    <input asp-for="Term" class="form-control form-control-custom" placeholder="Enter word" />
                    <span asp-validation-for="Term" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Category <span class="text-danger ms-1">*</span></label>
                    <div class="dropdown custom-dropdown-container" id="category-dropdown-container" data-bs-auto-close="outside">
                        <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="categoryBtn">
                            <span class="selected-items-display text-muted" id="category-selected-text">Any</span>
                            <i class="bi bi-chevron-down opacity-50 small"></i>
                        </button>
                        <input asp-for="NewCategory" type="hidden" id="NewCategory" />
                        <div class="dropdown-menu dropdown-menu-custom shadow rounded-4 w-100" id="category-dropdown">
                            <div class="dropdown-list-items" id="category-list">
                                <a href="#" class="dropdown-item dropdown-item-custom category-item rounded-4 mx-1 px-3 py-2" data-category-name="" data-category-label="Any" style="width: auto;">
                                    <span>Any</span>
                                    <i class="bi bi-check2 opacity-0"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3 d-none" id="manual-category-wrapper">
                        <label for="manual-category-input" class="form-label mb-2">New category name</label>
                        <input type="text" id="manual-category-input" class="form-control form-control-custom" placeholder="Type a new category name..." autocomplete="off" />
                    </div>

                    <span asp-validation-for="NewCategory" class="text-danger small d-block mt-1"></span>
                    <small class="text-muted">Pick an existing category or choose new category and type a name.</small>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label asp-for="DifficultyLevel" class="form-label">Difficulty Level</label>
                        <div class="dropdown custom-dropdown-container" id="difficulty-dropdown-container" data-bs-auto-close="outside">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="selected-items-display text-muted">Select Level...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items">
                                    <div class="dropdown-item-custom" data-value="" data-label="Select Level...">
                                        <span>Select Level...</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="A1" data-label="A1">
                                        <span>A1</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="A2" data-label="A2">
                                        <span>A2</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="B1" data-label="B1">
                                        <span>B1</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="B2" data-label="B2">
                                        <span>B2</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="C1" data-label="C1">
                                        <span>C1</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="C2" data-label="C2">
                                        <span>C2</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input asp-for="DifficultyLevel" type="hidden" id="DifficultyLevel" />
                        <span asp-validation-for="DifficultyLevel" class="text-danger small d-block mt-1"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PartOfSpeech" class="form-label">Part of Speech</label>
                        <div class="dropdown custom-dropdown-container" id="pos-dropdown-container" data-bs-auto-close="outside">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="selected-items-display text-muted">Select POS...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items">
                                    <div class="dropdown-item-custom" data-value="" data-label="Select POS...">
                                        <span>Select POS...</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="noun" data-label="Noun">
                                        <span>Noun</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="verb" data-label="Verb">
                                        <span>Verb</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="adjective" data-label="Adjective">
                                        <span>Adjective</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="adverb" data-label="Adverb">
                                        <span>Adverb</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="pronoun" data-label="Pronoun">
                                        <span>Pronoun</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="preposition" data-label="Preposition">
                                        <span>Preposition</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="conjunction" data-label="Conjunction">
                                        <span>Conjunction</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                    <div class="dropdown-item-custom" data-value="interjection" data-label="Interjection">
                                        <span>Interjection</span>
                                        <i class="bi bi-check2 opacity-0"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input asp-for="PartOfSpeech" type="hidden" id="PartOfSpeech" />
                        <span asp-validation-for="PartOfSpeech" class="text-danger small d-block mt-1"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Translation" class="form-label">Translation</label>
                    <input asp-for="Translation" class="form-control form-control-custom" placeholder="Enter translation" />
                    <span asp-validation-for="Translation" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Transcription" class="form-label">Transcription</label>
                    <input asp-for="Transcription" class="form-control form-control-custom" placeholder="e.g. /ˌserənˈdɪpɪti/" />
                    <span asp-validation-for="Transcription" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Meaning" class="form-label">Meaning</label>
                    <textarea asp-for="Meaning" class="form-control form-control-custom" rows="2" placeholder="Definition or meaning"></textarea>
                    <span asp-validation-for="Meaning" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Example" class="form-label">Example</label>
                    <textarea asp-for="Example" class="form-control form-control-custom" rows="2" placeholder="Example sentence"></textarea>
                    <span asp-validation-for="Example" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="d-flex gap-3 justify-content-center pt-4 border-top flex-wrap">
                    <button type="submit" class="btn-action-success rounded-4">
                        <i class="bi bi-plus-circle me-2"></i> Add Word
                    </button>
                    <a asp-action="Index" class="btn-action-outline-success rounded-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/admin-word-create.js" asp-append-version="true"></script>
}
