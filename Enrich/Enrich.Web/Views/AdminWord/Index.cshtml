@model Enrich.Web.ViewModels.SystemWordsIndexViewModel
@{
    ViewData["Title"] = "Manage System Dictionary";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-semibold fs-4 mb-0">Manage System Words</h1>
    <a asp-action="Create" class="btn btn-success rounded-4 px-4 shadow-sm">
        <i class="bi bi-plus-circle me-2"></i> Add Word
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success rounded-4 shadow-sm mb-4">
        <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger rounded-4 shadow-sm mb-4">
        <i class="bi bi-exclamation-octagon me-2"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label asp-for="SearchTerm" class="form-label small text-muted mb-1">Search</label>
                <input type="text" asp-for="SearchTerm" class="form-control border-1 shadow-sm rounded-4 py-2" placeholder="Search..." />
            </div>
            <div class="col-md-2">
                <label asp-for="CategoryFilter" class="form-label small text-muted mb-1">Category</label>
                <select asp-for="CategoryFilter" class="form-select border-1 shadow-sm rounded-4 py-2">
                    <option value="">All</option>
                    @if (Model.Categories != null)
                    {
                        foreach (var c in Model.Categories)
                        {
                            <option value="@c.Name">@c.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="PosFilter" class="form-label small text-muted mb-1">Parts of Speech</label>
                <select asp-for="PosFilter" class="form-select border-1 shadow-sm rounded-4 py-2">
                    <option value="">All</option>
                    <option value="noun">Noun</option>
                    <option value="verb">Verb</option>
                    <option value="adjective">Adjective</option>
                    <option value="adverb">Adverb</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="LevelFilter" class="form-label small text-muted mb-1">Level</label>
                <select asp-for="LevelFilter" class="form-select border-1 shadow-sm rounded-4 py-2">
                    <option value="">All</option>
                    <option value="A1">A1</option>
                    <option value="A2">A2</option>
                    <option value="B1">B1</option>
                    <option value="B2">B2</option>
                    <option value="C1">C1</option>
                    <option value="C2">C2</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-outline-secondary border-1 shadow-sm rounded-4 py-2 w-100">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
            </div>
        </form>
    </div>

    <div class="card-body p-0 mt-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0">Term</th>
                        <th class="py-3 border-0">Translation</th>
                        <th class="py-3 border-0">Category</th>
                        <th class="py-3 border-0">Level</th>
                        <th class="pe-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in Model.Words.Items)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-medium">@w.Term</td>
                            <td class="py-3 text-muted">@(w.Translation ?? "-")</td>
                            <td class="py-3 text-muted">@w.CategoryName</td>
                            <td class="py-3 text-muted">@(w.DifficultyLevel ?? "-")</td>
                            <td class="pe-4 py-3 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@w.Id" class="btn btn-sm btn-outline-secondary rounded-3">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@w.Id" method="post" onsubmit="return confirm('Delete this word?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-3">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Words.Items.Any())
                    {
                        <tr>
                            <td colspan="5" class="py-4 text-center text-muted">No words found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.Words.TotalCount > Model.PageSize)
{
    var totalPages = (int)Math.Ceiling(Model.Words.TotalCount / (double)Model.PageSize);
    <nav class="d-flex justify-content-center mt-4">
        <ul class="pagination pagination-sm shadow-sm rounded-4">
            @for (int idx = 1; idx <= totalPages; idx++)
            {
                <li class="page-item @(idx == Model.Words.Page ? "active" : "")">
                    <a class="page-link px-3 @(idx == Model.Words.Page ? "bg-success border-success" : "")" 
                       asp-action="Index" 
                       asp-route-page="@idx"
                       asp-route-SearchTerm="@Model.SearchTerm"
                       asp-route-CategoryFilter="@Model.CategoryFilter"
                       asp-route-PosFilter="@Model.PosFilter"
                       asp-route-LevelFilter="@Model.LevelFilter">@idx</a>
                </li>
            }
        </ul>
    </nav>
}