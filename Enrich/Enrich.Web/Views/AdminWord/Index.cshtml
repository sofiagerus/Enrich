@model Enrich.Web.ViewModels.SystemWordsIndexViewModel
@{
    ViewData["Title"] = "Manage System Dictionary";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-word.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-semibold fs-4 mb-0">Manage System Words</h1>
    <a asp-action="Create" class="btn-action-success">
        <i class="bi bi-plus-circle me-2"></i> Add Word
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show admin-alert mb-4" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show admin-alert mb-4" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card admin-card mb-4">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
        <form method="get" class="row g-3 align-items-end" id="filter-form">
            <div class="col-md-3">
                <label asp-for="SearchTerm" class="form-label small text-muted mb-1 fw-medium">Search</label>
                <input type="text" asp-for="SearchTerm" class="form-control form-control-custom" placeholder="Search..." />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1 fw-medium">Category</label>
                <div class="dropdown custom-dropdown-container" id="category-dropdown">
                    <button class="btn-dropdown" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="selected-items-display">All</span>
                        <i class="bi bi-chevron-down opacity-50 small"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-custom">
                        <div class="dropdown-item-custom" data-value="">Any</div>
                        @if (Model.Categories != null)
                        {
                            foreach (var c in Model.Categories)
                            {
                                <div class="dropdown-item-custom" data-value="@c.Name">@c.Name</div>
                            }
                        }
                    </div>
                </div>
                <input type="hidden" name="CategoryFilter" id="CategoryFilter" value="@Model.CategoryFilter" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1 fw-medium">Parts of Speech</label>
                <div class="dropdown custom-dropdown-container" id="pos-dropdown">
                    <button class="btn-dropdown" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="selected-items-display">All</span>
                        <i class="bi bi-chevron-down opacity-50 small"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-custom">
                        <div class="dropdown-item-custom" data-value="">Any</div>
                        <div class="dropdown-item-custom" data-value="noun">Noun</div>
                        <div class="dropdown-item-custom" data-value="verb">Verb</div>
                        <div class="dropdown-item-custom" data-value="adjective">Adjective</div>
                        <div class="dropdown-item-custom" data-value="adverb">Adverb</div>
                        <div class="dropdown-item-custom" data-value="preposition">Preposition</div>
                        <div class="dropdown-item-custom" data-value="conjunction">Conjunction</div>
                        <div class="dropdown-item-custom" data-value="interjection">Interjection</div>
                        <div class="dropdown-item-custom" data-value="pronoun">Pronoun</div>
                    </div>
                </div>
                <input type="hidden" name="PosFilter" id="PosFilter" value="@Model.PosFilter" />
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted mb-1 fw-medium">Level</label>
                <div class="dropdown custom-dropdown-container" id="level-dropdown">
                    <button class="btn-dropdown" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="selected-items-display">All</span>
                        <i class="bi bi-chevron-down opacity-50 small"></i>
                    </button>
                    <div class="dropdown-menu dropdown-menu-custom">
                        <div class="dropdown-item-custom" data-value="">Any</div>
                        <div class="dropdown-item-custom" data-value="A1">A1</div>
                        <div class="dropdown-item-custom" data-value="A2">A2</div>
                        <div class="dropdown-item-custom" data-value="B1">B1</div>
                        <div class="dropdown-item-custom" data-value="B2">B2</div>
                        <div class="dropdown-item-custom" data-value="C1">C1</div>
                        <div class="dropdown-item-custom" data-value="C2">C2</div>
                    </div>
                </div>
                <input type="hidden" name="LevelFilter" id="LevelFilter" value="@Model.LevelFilter" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn-action-outline-success w-100" style="padding-top: 0.6rem; padding-bottom: 0.6rem;">
                    <i class="bi bi-funnel me-1"></i> Filter
                </button>
            </div>
        </form>
    </div>

    <div class="card-body p-0 mt-4 border-top">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0 fw-semibold text-dark">Term</th>
                        <th class="py-3 border-0 fw-semibold text-dark">Translation</th>
                        <th class="py-3 border-0 fw-semibold text-dark">Category</th>
                        <th class="py-3 border-0 fw-semibold text-dark">Part of Speech</th>
                        <th class="py-3 border-0 fw-semibold text-dark">Level</th>
                        <th class="pe-4 py-3 border-0 text-end fw-semibold text-dark">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in Model.Words.Items)
                    {
                        <tr>
                            <td class="ps-4 py-3 fw-medium text-dark">@w.Term</td>
                            <td class="py-3 text-muted">@(w.Translation ?? "-")</td>
                            <td class="py-3 text-muted">@w.CategoryName</td>
                            <td class="py-3 text-muted text-capitalize">@(w.PartOfSpeech ?? "-")</td>
                            <td class="py-3 text-muted">@(w.DifficultyLevel ?? "-")</td>
                            <td class="pe-4 py-3 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@w.Id" class="btn btn-sm border text-secondary btn-icon-action bg-white">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@w.Id" method="post" onsubmit="return confirm('Delete this word?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm border text-danger btn-icon-action bg-white" style="border-color: #f5c2c7 !important;">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Words.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="py-5 text-center text-muted">No words found matching your filters.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.Words.TotalCount > Model.PageSize)
{
    var totalPages = (int)Math.Ceiling(Model.Words.TotalCount / (double)Model.PageSize);
    <nav class="d-flex justify-content-center mt-4 mb-5">
        <ul class="pagination pagination-sm rounded-4 gap-1">
            @for (int idx = 1; idx <= totalPages; idx++)
            {
                <li class="page-item @(idx == Model.Words.Page ? "active" : "")">
                    <a class="page-link rounded-3 px-3 @(idx == Model.Words.Page ? "bg-success border-success text-white" : "text-success border-0 bg-white")" 
                       asp-action="Index" 
                       asp-route-page="@idx"
                       asp-route-SearchTerm="@Model.SearchTerm"
                       asp-route-CategoryFilter="@Model.CategoryFilter"
                       asp-route-PosFilter="@Model.PosFilter"
                       asp-route-LevelFilter="@Model.LevelFilter"
                       style="box-shadow: none;">@idx</a>
                </li>
            }
        </ul>
    </nav>
}

@section Scripts {
    <script src="~/js/admin-word.js" asp-append-version="true"></script>
}