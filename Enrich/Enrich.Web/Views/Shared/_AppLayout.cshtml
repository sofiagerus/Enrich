@inject UserManager<User> UserManager
@using Enrich.DAL.Entities
@using Microsoft.AspNetCore.Identity

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var roles = currentUser != null ? await UserManager.GetRolesAsync(currentUser) : new List<string>();
    var displayRole = roles.FirstOrDefault() ?? "Student";

    // Отримуємо поточну дію та контролер для підсвітки меню
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Enrich</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex flex-nowrap vh-100 overflow-hidden">

        <div class="enrich-sidebar d-flex flex-column p-2 h-100" style="flex-shrink: 0;">

            <a href="/" class="d-flex align-items-center mb-2 text-dark text-decoration-none px-3 flex-shrink-0">
                <span class="fs-4 fw-medium text-dark">Enrich</span>
            </a>

            <div class="flex-grow-1 overflow-y-auto" style="scrollbar-width: none; -ms-overflow-style: none;">

                <div class="sidebar-heading">Main menu</div>
                <ul class="nav nav-pills flex-column mb-4">
                    <li class="nav-item">
                        <a href="#" class="nav-link @(currentAction == "Words" ? "active" : "")">Words</a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link @(currentAction == "Collections" ? "active" : "")">Collections</a>
                    </li>
                    <li class="nav-item"><a href="#" class="nav-link @(currentAction == "MyWords" ? "active" : "")">My words</a></li>
                    <li class="nav-item"><a href="#" class="nav-link @(currentAction == "MyCollections" ? "active" : "")">My collections</a></li>
                    <li class="nav-item"><a href="#" class="nav-link @(currentAction == "Community" ? "active" : "")">Community</a></li>
                    <li class="nav-item"><a href="#" class="nav-link @(currentAction == "Generator" ? "active" : "")">Generator</a></li>
                </ul>

                <div class="sidebar-heading">Administration</div>
                <ul class="nav nav-pills flex-column mb-2">
                    <li class="nav-item">
                        <a asp-controller="Admin" asp-action="Browse"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                            Manage users
                        </a>
                    </li>
                    <li class="nav-item"><a href="#" class="nav-link">Manage words</a></li>
                    <li class="nav-item"><a href="#" class="nav-link">Manage collections</a></li>
                    <li class="nav-item"><a href="#" class="nav-link">Pending collections</a></li>
                </ul>

            </div>

            <div class="mt-auto pt-3 flex-shrink-0">
                <div class="sidebar-heading">Account</div>

                <div class="d-flex align-items-center px-2 py-2 text-dark">
                    <div class="bg-secondary text-white rounded-circle me-3 d-flex justify-content-center align-items-center" style="width: 45px; height: 45px; opacity: 0.8;">
                        <span class="fs-5 fw-bold">
                            @(currentUser?.UserName?.Substring(0, 1).ToUpper() ?? "?")
                        </span>
                    </div>

                    <div class="lh-1">
                        <a asp-controller="Account" asp-action="Profile"
                               class="text-decoration-none text-dark fw-semibold mb-1 d-block @(currentAction == "Profile" ? "text-primary" : "")"
                               style="font-size: 0.95rem;">
                            @(currentUser?.UserName ?? "Guest")
                        </a>
                        <div class="text-muted mt-1" style="font-size: 0.8rem;">@displayRole</div>
                    </div>

                    <a asp-controller="Account" asp-action="Settings" class="ms-auto link-dark text-decoration-none @(currentAction == "Settings" ? "text-primary" : "")">
                        <i class="bi bi-gear fs-5"></i>
                    </a>
                </div>
            </div>

        </div>

        <main class="flex-grow-1 p-4 bg-white overflow-auto h-100">
            @RenderBody()
        </main>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>