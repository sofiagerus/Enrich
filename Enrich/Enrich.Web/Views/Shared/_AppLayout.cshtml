@inject UserManager<User> UserManager
@using Enrich.DAL.Entities
@using Microsoft.AspNetCore.Identity

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var roles = currentUser != null ? await UserManager.GetRolesAsync(currentUser) : new List<string>();
    var displayRole = roles.FirstOrDefault() ?? "Student";

    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();

    const string activeClass = "bg-success text-white";
    const string inactiveClass = "text-dark";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Enrich</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.min.css" asp-append-version="true" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <style>
        .sidebar-container i.bi {
            -webkit-text-stroke: 0.4px;
        }

        .sidebar-container .nav-link {
            transition: background-color 0.15s ease-in-out, color 0.15s ease-in-out;
        }

        .sidebar-container .nav-link:hover:not(.bg-success) {
            background-color: rgba(0, 0, 0, 0.05);
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="d-flex flex-nowrap vh-100 overflow-hidden">

        <div class="sidebar-container d-flex flex-column p-2 h-100 bg-success" style="width: 280px; flex-shrink: 0; --bs-bg-opacity: .05;">

            <a href="/" class="d-flex align-items-center mb-5 text-dark text-decoration-none px-3 flex-shrink-0">
                <span class="fs-4 text-dark" style="font-weight: 600;">Enrich</span>
            </a>

            <div class="flex-grow-1 overflow-y-auto">

                <div class="text-secondary mb-2 px-3" style="font-size: 0.85rem; font-weight: 600;">Main menu</div>
                <ul class="nav flex-column nav-pills gap-1 mb-3">
                    <li class="nav-item">
                        <a asp-controller="Word" asp-action="Index" class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentAction == "Index" && currentController == "Word" ? activeClass : inactiveClass)"
                           style="font-weight: 500; font-size: 0.95rem;">
                            <i class="bi bi-book me-3 fs-6"></i>Words
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Collection" asp-action="Index" class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "Collection" && currentAction == "Index" ? activeClass : inactiveClass)"
                           style="font-weight: 500; font-size: 0.95rem;">
                            <i class="bi bi-collection me-3 fs-6"></i>Collections
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Word" asp-action="MyWords"
                           class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "Word" && (currentAction == "MyWords" || currentAction == "Create" || currentAction == "Edit") ? activeClass : inactiveClass)"
                           style="font-weight: 500; font-size: 0.95rem;">
                            <i class="bi bi-bookmark me-3 fs-6"></i>My words
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Bundle" asp-action="Index"
                           class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "Bundle" && (currentAction == "Index" || currentAction == "Details" || currentAction == "Edit" || currentAction == "Create") ? activeClass : inactiveClass)"
                           style="font-weight: 500; font-size: 0.95rem;">
                            <i class="bi bi-folder me-3 fs-6"></i>My collections
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Collection" asp-action="Community" class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "Collection" && currentAction == "Community" ? activeClass : inactiveClass)"
                           style="font-weight: 500; font-size: 0.95rem;">
                            <i class="bi bi-people me-3 fs-6"></i>Community
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="Bundle" asp-action="Generator" class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentAction == "Generator" && currentController == "Bundle" ? activeClass : inactiveClass)"
                           style="font-weight: 500; font-size: 0.95rem;">
                            <i class="bi bi-stars me-3 fs-6"></i>Generator
                        </a>
                    </li>
                </ul>

                @if (roles.Contains("Admin"))
                {
                    <div class="text-secondary mb-2 px-3 mt-4" style="font-size: 0.85rem; font-weight: 600;">Administration</div>
                    <ul class="nav flex-column nav-pills gap-1 mb-1">
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="Browse"
                               class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "Admin" && currentAction != "PendingBundles" ? activeClass : inactiveClass)"
                               style="font-weight: 500; font-size: 0.95rem;">
                                <i class="bi bi-person-gear me-3 fs-6"></i>Manage users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Category" asp-action="Index"
                               class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "Category" ? activeClass : inactiveClass)"
                               style="font-weight: 500; font-size: 0.95rem;">
                                <i class="bi bi-tags-fill me-3 fs-6"></i>Manage categories
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="AdminWord" asp-action="Index"
                               class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "AdminWord" ? activeClass : inactiveClass)"
                               style="font-weight: 500; font-size: 0.95rem;">
                                <i class="bi bi-book-fill me-3 fs-6"></i>Manage words
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="AdminBundle" asp-action="Index"
                               class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "AdminBundle" && currentAction != "Community" ? activeClass : inactiveClass)"
                               style="font-weight: 500; font-size: 0.95rem;">
                                <i class="bi bi-folder-fill me-3 fs-6"></i>Manage collections
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="AdminBundle" asp-action="Community"
                               class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "AdminBundle" && currentAction == "Community" ? activeClass : inactiveClass)"
                               style="font-weight: 500; font-size: 0.95rem;">
                                <i class="bi bi-globe me-3 fs-6"></i>Manage community
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Admin" asp-action="PendingBundles" class="nav-link d-flex align-items-center rounded-4 py-2 px-3 ms-2 me-3 @(currentController == "Admin" && currentAction == "PendingBundles" ? activeClass : inactiveClass)" style="font-weight: 500; font-size: 0.95rem;">
                                <i class="bi bi-hourglass-split me-3 fs-6"></i>Pending collections
                            </a>
                        </li>
                    </ul>
                }

            </div>

            <div class="mt-auto pt-2 flex-shrink-0">
                <div class="text-secondary mb-2 px-3" style="font-size: 0.85rem; font-weight: 600;">Account</div>

                <div class="d-flex align-items-center px-3 py-2 text-dark">
                    <a asp-controller="Notification" asp-action="Index" class="position-relative text-decoration-none">
                        <div class="bg-secondary text-white rounded-circle me-3 d-flex justify-content-center align-items-center flex-shrink-0" style="width: 40px; height: 40px; opacity: 0.8;">
                            <i class="bi bi-person-fill fs-5"></i>
                        </div>
                        <span id="notifBadge"
                              class="position-absolute top-0 start-0 translate-middle badge rounded-pill bg-danger"
                              style="font-size: 0.6rem; display: none;"></span>
                    </a>

                    <div class="lh-1 overflow-hidden">
                        <a asp-controller="Account" asp-action="Settings" asp-route-tab="profile"
                           class="text-decoration-none text-dark d-block text-truncate @(currentAction == "Settings" ? "text-success" : "")"
                           style="font-weight: 600; font-size: 0.95rem; margin-bottom: 2px;">
                            @(currentUser?.UserName ?? "Guest")
                        </a>
                        <div class="text-muted mt-1 text-truncate" style="font-size: 0.8rem;">@displayRole</div>
                    </div>

                    <a asp-controller="Account" asp-action="Settings"
                       class="nav-link d-flex align-items-center justify-content-center rounded-4 ms-auto me-1"
                       style="width: 38px; height: 38px; padding: 0;">
                        <i class="bi bi-gear fs-5"></i>
                    </a>
                </div>
            </div>

        </div>

        <main class="flex-grow-1 p-4 bg-success overflow-auto h-100" style="--bs-bg-opacity: .03;">
            @RenderBody()
        </main>

    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1100">
        <div id="appToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body" id="appToastMessage"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function showToast(message, type = 'success') {
            const toastEl = document.getElementById('appToast');
            const toastMessageEl = document.getElementById('appToastMessage');

            toastMessageEl.textContent = message;

            toastEl.classList.remove('bg-success', 'bg-danger', 'bg-warning', 'bg-info');
            if (type === 'success') toastEl.classList.add('bg-success');
            else if (type === 'danger') toastEl.classList.add('bg-danger');
            else if (type === 'warning') toastEl.classList.add('bg-warning');
            else if (type === 'info') toastEl.classList.add('bg-info');
            const toast = new bootstrap.Toast(toastEl);
            toast.show();
        }
    </script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
            // ── SignalR real-time notification client ──────────────────────────
            (function () {
                const badge = document.getElementById('notifBadge');

                // Fetch current unread count on page load
                fetch('/Notification/UnreadCount')
                    .then(r => r.json())
                    .then(data => updateBadge(data.count))
                    .catch(() => { });

                function updateBadge(count) {
                    if (!badge) return;
                    if (count > 0) {
                        badge.textContent = count > 99 ? '99+' : count;
                        badge.style.display = '';
                    } else {
                        badge.style.display = 'none';
                    }
                }

                // Connect to SignalR hub
                const connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/notifications')
                    .withAutomaticReconnect()
                    .build();

                connection.on('ReceiveNotification', function (notification) {
                    // Show toast
                    showToast(notification.message, 'success');

                    // Increment badge
                    const currentCount = parseInt(badge?.textContent) || 0;
                    updateBadge(currentCount + 1);
                });

                connection.start()
                    .catch(err => console.warn('SignalR connection error:', err));
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>