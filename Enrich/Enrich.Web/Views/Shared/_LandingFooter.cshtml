@inject IViewLocalizer L
@{
    var rawName = System.Globalization.CultureInfo.CurrentUICulture.DisplayName;
    var capitalizedLanguage = char.ToUpper(rawName[0]) + rawName.Substring(1);
}

<footer class="mt-auto py-4 mt-5 bg-success bg-opacity-10">
    <div class="container d-flex flex-column gap-3">
        <div class="d-flex justify-content-center justify-content-md-start gap-4 mb-3" style="font-size: 14px;">
            <div class="nav-item">
                <a class="nav-link hover-underline" href="#features">
                    <span>@L["Footer.TermsOfService"]</span>
                </a>
            </div>
            <div class="nav-item">
                <a class="nav-link hover-underline" href="#features">
                    <span>@L["Footer.PrivacyPolicy"]</span>
                </a>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="small text-muted">&copy; @DateTime.Now.Year Enrich. @L["Footer.Rights"]</span>

            <div class="d-flex align-items-center gap-2">
                <div class="dropdown">
                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3 dropdown-toggle" data-bs-toggle="dropdown">
                        @capitalizedLanguage
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="?culture=uk">Українська</a></li>
                        <li><a class="dropdown-item" href="?culture=en">English</a></li>
                    </ul>
                </div>

                <button class="btn btn-sm btn-outline-secondary rounded-5" onclick="toggleTheme()" title="Toggle theme">
                    <span id="themeIcon">🌙</span>
                </button>
            </div>
        </div>
    </div>
</footer>