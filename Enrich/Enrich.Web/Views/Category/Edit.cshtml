@model Enrich.Web.ViewModels.CategoryViewModel

@{
    ViewData["Title"] = "Edit Category";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

<div class="d-flex align-items-center mb-4 gap-3">
    <a asp-action="Index" class="btn-sm btn-outline-secondary rounded-3 d-flex align-items-center gap-1 text-decoration-none">
        <i class="bi bi-arrow-left"></i> Back
    </a>
    <h1 class="fw-semibold fs-4 mb-0">Edit Category</h1>
</div>

<div class="card border shadow-none rounded-4 mx-auto" style="max-width: 600px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-4">
                <label asp-for="Name" class="form-label mb-1">Category Name</label>
                <input asp-for="Name" class="form-control rounded-4 py-2 border shadow-none" 
                       placeholder="Enter new category name" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-action-success rounded-4">
                    <i class="bi bi-check-circle me-2"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-action-outline-success rounded-4">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
