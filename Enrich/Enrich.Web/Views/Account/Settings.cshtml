@model Enrich.Web.ViewModels.UpdateProfileViewModel

@{
    ViewData["Title"] = "Settings";
    var activeTab = (string)(ViewBag.ActiveTab ?? "profile");
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/css/account-settings.css" asp-append-version="true" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/css/account-settings.min.css" asp-append-version="true" />
    </environment>
}

<div class="container mt-5">
    <div class="row">

        <div class="col-md-3">
            <div class="nav flex-column nav-pills gap-2 account-settings-nav" role="tablist" aria-orientation="vertical">
                <a class="nav-link fw-semibold d-flex align-items-center py-2 px-3 rounded-4 settings-nav-link @(activeTab == "profile" ? "active" : "")"
                   asp-action="Settings" asp-controller="Account" asp-route-tab="profile">
                    <i class="bi bi-person me-3 fs-5"></i>Profile
                </a>
                <a class="nav-link fw-semibold d-flex align-items-center py-2 px-3 mb-4 rounded-4 settings-nav-link @(activeTab == "interface" ? "active" : "")"
                   asp-action="Settings" asp-controller="Account" asp-route-tab="interface">
                    <i class="bi bi-display me-3 fs-5"></i>Interface
                </a>
                <form asp-action="Logout" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-link text-danger fw-semibold bg-transparent p-0 w-100 text-start d-flex align-items-center py-2 px-3 rounded-4 settings-nav-link settings-nav-link-logout">
                        <i class="bi bi-box-arrow-right me-3 fs-5"></i>Logout
                    </button>
                </form>
            </div>
        </div>

        <div class="col-md-9">
            <div class="settings-panel">
                @if (activeTab == "profile")
                {
                    <partial name="_ProfileSettings" model="Model" />
                }
                else if (activeTab == "interface")
                {
                    <partial name="_InterfaceSettings" />
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <environment include="Development">
        <script src="~/js/account-settings.js" asp-append-version="true"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/js/account-settings.min.js" asp-append-version="true"></script>
    </environment>
}
