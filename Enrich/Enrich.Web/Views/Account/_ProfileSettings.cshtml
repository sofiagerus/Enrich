@model Enrich.Web.ViewModels.UpdateProfileViewModel

<h4 class="mb-4 fw-normal fs-4 text-dark">Profile Settings</h4>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-4">
    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center settings-avatar">
        <i class="bi bi-person-fill text-white fs-3"></i>
    </div>
</div>

<form asp-action="Settings" asp-controller="Account" asp-route-tab="profile" method="post" class="settings-form">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

    <div class="mb-3">
        <label asp-for="Username" class="form-label mb-1">Username</label>
        <input asp-for="Username" class="form-control py-2" placeholder="Username" />
        <span asp-validation-for="Username" class="text-danger small d-block mt-1"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label mb-1">
            Email <i class="bi bi-lock-fill ms-1 text-muted small" title="Email cannot be changed"></i>
        </label>
        <input asp-for="Email"
               class="form-control py-2 bg-light text-muted"
               readonly />
    </div>

    <div class="mb-4">
        <label asp-for="Bio" class="form-label mb-1">Bio</label>
        <textarea asp-for="Bio" class="form-control py-2" rows="3" placeholder="Tell something about yourself..."></textarea>
        <span asp-validation-for="Bio" class="text-danger small d-block mt-1"></span>
    </div>

    <button type="submit" class="btn btn-action-success">Save changes</button>
</form>
