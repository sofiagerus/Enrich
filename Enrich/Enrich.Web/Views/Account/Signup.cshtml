@model Enrich.Web.ViewModels.SignupViewModel

@{
    ViewData["Title"] = "Sign up to Enrich";
    Layout = "_AuthLayout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-8 col-md-6 col-lg-4">

            <h1 class="text-center mb-4 fs-4 fw-normal text-dark">Sign up to Enrich</h1>

            <form asp-action="Signup" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label mb-1">Email</label>
                    <input asp-for="Email" class="form-control border-1 rounded-4 py-2 custom-gray-bg" placeholder="Email" />
                    <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label mb-1">Username</label>
                    <input asp-for="Username" class="form-control border-1 rounded-4 py-2 custom-gray-bg" placeholder="Username" />
                    <span asp-validation-for="Username" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label mb-1">Password</label>
                    <input asp-for="Password" type="password" class="form-control border-1 rounded-4 py-2 custom-gray-bg" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                </div>

                <p class="small text-dark mb-4 terms-text lh-base">
                    By creating an account, you agree to our <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a>.
                </p>

                <button type="submit" class="btn btn-success w-100 rounded-4 py-2 custom-btn mb-4">Create account</button>
            </form>

            <div class="text-center small text-dark">
                Already have an account?
                <a asp-controller="Account" asp-action="Login" class="text-dark text-decoration-underline">Log in</a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}