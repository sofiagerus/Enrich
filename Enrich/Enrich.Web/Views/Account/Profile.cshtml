@model Enrich.DAL.Entities.User

@{
    ViewData["Title"] = "Мій профіль";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold">Profile</h5>
                </div>
                <div class="card-body p-4">

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="Email" class="form-label fw-semibold text-muted">Електронна пошта</label>
                            <input asp-for="Email" class="form-control bg-light" disabled />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label fw-semibold">Ім'я користувача</label>
                            <input asp-for="UserName" class="form-control" />
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>
</div>