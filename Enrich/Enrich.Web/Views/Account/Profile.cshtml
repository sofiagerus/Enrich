@model Enrich.Web.ViewModels.UpdateProfileViewModel

@{
    ViewData["Title"] = "Профіль";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-3">
            <div class="nav flex-column nav-pills" role="tablist" aria-orientation="vertical">
                <a class="nav-link active bg-light text-dark shadow-sm fw-semibold mb-2" href="#" role="tab">
                    <i class="bi bi-person me-2"></i>Profile
                </a>
                <a class="nav-link text-dark fw-semibold mb-5" href="#" role="tab">
                    <i class="bi bi-display me-2"></i>Interface
                </a>
                <form asp-action="Logout" asp-controller="Account" method="post">
                    <button type="submit" class="nav-link text-danger fw-semibold border-0 bg-transparent p-0">
                        <i class="bi bi-box-arrow-right me-2"></i>Logout
                    </button>
                </form>
            </div>
        </div>

        <div class="col-md-9">
            <h4 class="mb-4 fw-bold">Profile Settings</h4>

            <div class="mb-4">
                <div class="bg-secondary rounded-circle d-inline-block shadow-sm" style="width: 80px; height: 80px;"></div>
            </div>

            <form asp-action="Profile" asp-controller="Account" method="post">
                <div class="mb-4">
                    <label asp-for="Username" class="form-label text-muted mb-1">Username</label>
                    <input asp-for="Username" class="form-control bg-light border-0 shadow-sm" />
                    <span asp-validation-for="Username" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label text-muted mb-1">
                        Email <i class="bi bi-lock-fill ms-1" title="Цей ідентифікатор не можна змінити"></i>
                    </label>
                    <div class="input-group">
                        <input asp-for="Email"
                               class="form-control bg-secondary-subtle border-0 shadow-sm text-muted"
                               style="cursor: not-allowed; opacity: 0.8;"
                               readonly />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Bio" class="form-label text-muted mb-1">Bio</label>
                    <textarea asp-for="Bio" class="form-control bg-light border-0 shadow-sm" rows="3"></textarea>
                    <span asp-validation-for="Bio" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-secondary text-dark shadow-sm px-4 fw-bold"
                        style="background-color: #d3d3d3; border-color: #d3d3d3;">
                    Save changes
                </button>
            </form>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="mt-3">
                    <div asp-validation-summary="All" class="text-danger small p-3 bg-light rounded border-start border-danger border-4"></div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[title]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}
