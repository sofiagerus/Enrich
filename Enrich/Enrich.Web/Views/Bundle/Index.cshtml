@using Enrich.Web.ViewModels
@model BundleIndexViewModel

@{
    ViewData["Title"] = "My Collections";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/css/collections.css" asp-append-version="true" />
    </environment>
    <environment exclude="Development">
        <link rel="stylesheet" href="~/css/collections.min.css" asp-append-version="true" />
    </environment>
}

<div class="container-fluid py-4">
    <div class="row align-items-start">
        <div class="col-lg-9">
            <!-- Burger Menu Button (видна тільки на мобілі) -->
            <div class="d-lg-none mb-3">
                <button class="btn btn-outline-success" type="button" 
                        data-bs-toggle="offcanvas" data-bs-target="#sidebarFilters">
                    <i class="bi bi-funnel me-2"></i> Filters
                </button>
            </div>

            <div class="d-flex flex-wrap gap-3 mb-3 align-items-center">
                <div class="input-group flex-grow-1 search-box overflow-hidden" style="max-width: 600px;">
                    <span class="input-group-text border-0 bg-transparent ps-3">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="searchTerm" class="form-control border-0 bg-transparent p-2"
                           placeholder="Search collections..." value="" onkeyup="debounceSearch()">
                </div>

                <button class="btn btn-action ms-auto">
                    <i class="bi bi-sort-down me-2"></i> Order by
                </button>
            </div>

            <div class="mb-4 text-start">
                <a asp-action="Create" asp-controller="Bundle" class="btn btn-action-success rounded-4 text-decoration-none">
                    <i class="bi bi-plus-lg me-1"></i> Add New Collection
                </a>
            </div>

            <div id="bundles-list-container" data-page-size="@Model.PageSize">
                <partial name="_MyBundleListPartial" model="Model.Bundles" />
            </div>
        </div>

        <!-- Sidebar для десктопу (видна тільки на lg+) -->
        <div class="col-lg-3 ps-lg-4 d-none d-lg-block">
            <partial name="_CollectionFiltersPartial" model="Model.Categories" />
        </div>

        <!-- Offcanvas для мобілі (видна тільки на мобілі) -->
        <div class="offcanvas offcanvas-start" tabindex="-1" id="sidebarFilters">
            <div class="offcanvas-header bg-success text-white">
                <h5 class="offcanvas-title">Filters</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
            </div>
            <div class="offcanvas-body p-0">
                <partial name="_CollectionFiltersPartial" model="Model.Categories" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <environment include="Development">
        <script src="~/js/my-collections.js" asp-append-version="true"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/js/my-collections.min.js" asp-append-version="true"></script>
    </environment>
}
