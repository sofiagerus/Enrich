@model Enrich.BLL.DTOs.PagedResult<Enrich.BLL.DTOs.BundleDTO>

@{
    ViewData["Title"] = "My Collections";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <style>
        .bundle-card {
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: pointer;
            height: 100%;
            display: flex;
            flex-direction: column;
            border: none;
            border-radius: 1rem;
            overflow: hidden;
        }

        .bundle-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
        }

        .bundle-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .bundle-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            padding: 1.25rem;
        }

        .bundle-title {
            font-weight: 600;
            margin-bottom: 0.5rem;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .bundle-description {
            font-size: 0.875rem;
            color: #6c757d;
            margin-bottom: 1rem;
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            flex-grow: 1;
        }

        .bundle-meta {
            font-size: 0.8rem;
            color: #9ca3af;
            display: flex;
            justify-content: space-between;
            border-top: 1px solid #e5e7eb;
            padding-top: 0.75rem;
            margin-top: auto;
        }

        .bundle-meta-item {
            display: flex;
            align-items: center;
            gap: 0.25rem;
        }

        .bundle-actions {
            display: flex;
            gap: 0.5rem;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        .bundle-actions button,
        .bundle-actions a {
            flex: 1;
            font-size: 0.875rem;
        }

        .status-badge {
            display: inline-block;
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .status-draft {
            background-color: #fef3c7;
            color: #92400e;
        }

        .status-pending {
            background-color: #dbeafe;
            color: #0c4a6e;
        }

        .status-published {
            background-color: #d1fae5;
            color: #065f46;
        }

        .status-rejected {
            background-color: #fee2e2;
            color: #991b1b;
        }

        .no-bundles {
            text-align: center;
            padding: 3rem 1rem;
        }

        .no-bundles-icon {
            font-size: 3rem;
            color: #d1d5db;
            margin-bottom: 1rem;
        }

        .create-bundle-btn {
            border-radius: 1rem;
        }

        .search-box {
            border-radius: 1rem;
        }
    </style>
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
        <h1 class="fw-semibold fs-4 mb-0">
            <i class="bi bi-collection"></i> My Collections
        </h1>
        <a asp-action="Create" asp-controller="Bundle" class="btn btn-primary create-bundle-btn">
            <i class="bi bi-plus-circle"></i> New Collection
        </a>
    </div>

    <!-- Search Bar -->
    <div class="mb-4">
        <input type="text" 
               id="search-input" 
               class="form-control search-box" 
               placeholder="Search by collection name...">
    </div>

    <!-- Success/Error Messages -->
    @if (TempData.ContainsKey("SuccessMessage"))
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData.ContainsKey("ErrorMessage"))
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
            <i class="bi bi-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Bundles Grid -->
    <div class="row g-4" id="bundles-container">
        @if (Model?.Items?.Any() == true)
        {
            @foreach (var bundle in Model.Items)
            {
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card bundle-card">
                        @if (!string.IsNullOrEmpty(bundle.ImageUrl))
                        {
                            <img src="@bundle.ImageUrl" alt="@bundle.Title" class="bundle-image">
                        }
                        else
                        {
                            <div class="bundle-image d-flex align-items-center justify-content-center">
                                <i class="bi bi-collection fs-1 text-white" style="opacity: 0.5;"></i>
                            </div>
                        }

                        <div class="bundle-content">
                            <h5 class="bundle-title">@bundle.Title</h5>

                            @if (!string.IsNullOrEmpty(bundle.Description))
                            {
                                <p class="bundle-description">@bundle.Description</p>
                            }

                            <div class="bundle-meta">
                                <div class="bundle-meta-item">
                                    <i class="bi bi-book"></i> @bundle.WordCount words
                                </div>
                                <div class="bundle-meta-item">
                                    <i class="bi bi-tag"></i> @bundle.CategoryCount
                                </div>
                                <div class="bundle-meta-item">
                                    <span class="status-badge status-@bundle.Status.ToLower()">
                                        @bundle.Status
                                    </span>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="bundle-actions">
                                <a asp-action="Edit" 
                                   asp-controller="Bundle" 
                                   asp-route-id="@bundle.Id"
                                   class="btn btn-sm btn-outline-primary rounded-2 flex-grow-1">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>

                                <form asp-action="Delete" 
                                      asp-controller="Bundle" 
                                      asp-route-id="@bundle.Id" 
                                      method="post"
                                      style="flex: 1;"
                                      onsubmit="return confirm('Are you sure you want to delete this bundle?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-2 w-100">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="no-bundles">
                    <div class="no-bundles-icon">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <h3 class="text-secondary">You have no collections</h3>
                    <p class="text-muted mb-3">Create your first collection to start organizing words</p>
                    <a asp-action="Create" asp-controller="Bundle" class="btn btn-primary create-bundle-btn">
                        <i class="bi bi-plus-circle"></i> Create Collection
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model?.TotalCount > 0 && Model.TotalCount > Model.PageSize)
    {
        var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);

        <nav aria-label="Page navigation" class="mt-5">
            <ul class="pagination justify-content-center">
                @if (Model.Page > 1)
                {
                    <li class="page-item">
                        <a class="page-link rounded-2" href="?page=1">First</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link rounded-2" href="?page=@(Model.Page - 1)">Previous</a>
                    </li>
                }

                @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(totalPages, Model.Page + 2); i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link rounded-2" href="?page=@i">@i</a>
                    </li>
                }

                @if (Model.Page < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link rounded-2" href="?page=@(Model.Page + 1)">Next</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link rounded-2" href="?page=@totalPages">Last</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('search-input');
        const bundlesContainer = document.getElementById('bundles-container');

        searchInput?.addEventListener('input', async function() {
            const searchTerm = this.value;
            if (searchTerm.length > 0) {
                try {
                    const response = await fetch(`/bundle/GetMyBundles?searchTerm=${encodeURIComponent(searchTerm)}&page=1&pageSize=20`);
                    const data = await response.json();
                    
                    if (data.items && data.items.length > 0) {
                        console.log('Search results:', data);
                    }
                } catch (error) {
                    console.error('Search error:', error);
                }
            }
        });
    </script>
}
