@model Enrich.Web.ViewModels.GeneratorViewModel
@{
    ViewData["Title"] = "Bundle Generator";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row align-items-start">
        <!-- Left Column: Parameters -->
        <div class="col-lg-4">
            <div class="sidebar-panel mb-4">
                <h6 class="mb-4 text-dark" style="font-weight: 500; font-size: 1.1rem;">Bundle Information</h6>
                
                <div class="mb-4">
                    <label class="small fw-medium text-dark mb-2 ps-1">Title</label>
                    <div class="search-box">
                        <input type="text" id="bundleTitle" class="form-control border-0 bg-transparent px-3" 
                               placeholder="Auto-generated collection" value="@Model.Title">
                    </div>
                </div>

                <div class="mb-2">
                    <label class="small fw-medium text-dark mb-2 ps-1">Description</label>
                    <div class="search-box">
                        <textarea id="bundleDescription" class="form-control border-0 bg-transparent px-3" 
                                  rows="3" placeholder="Describe your collection...">@Model.Description</textarea>
                    </div>
                </div>

                <div class="sidebar-divider"></div>
                
                <h6 class="mb-4 text-dark" style="font-weight: 500; font-size: 1.1rem;">Add Generation Rules</h6>

                <!-- Category Dropdown -->
                <div class="mb-4">
                    <label class="small fw-medium text-dark mb-2 ps-1">Category</label>
                    <div class="dropdown custom-dropdown" id="categoryDropdownContainer">
                        <button class="btn btn-dropdown w-100 text-start d-flex justify-content-between align-items-center" 
                                type="button" data-bs-toggle="dropdown" aria-expanded="false" id="categoryBtn">
                            <span class="selected-text">Any</span>
                            <i class="bi bi-chevron-down small opacity-50"></i>
                        </button>
                        <input type="hidden" id="categorySelect" value="">
                        <ul class="dropdown-menu w-100 shadow border-0 mt-1">
                            <li><a class="dropdown-item active" href="#" data-value="">Any</a></li>
                            @foreach (var cat in Model.Categories)
                            {
                                <li><a class="dropdown-item" href="#" data-value="@cat.Id">@cat.Name</a></li>
                            }
                        </ul>
                    </div>
                </div>

                <!-- Part of Speech Dropdown -->
                <div class="mb-4">
                    <label class="small fw-medium text-dark mb-2 ps-1">Part of Speech</label>
                    <div class="dropdown custom-dropdown" id="posDropdownContainer">
                        <button class="btn btn-dropdown w-100 text-start d-flex justify-content-between align-items-center" 
                                type="button" data-bs-toggle="dropdown" aria-expanded="false" id="posBtn">
                            <span class="selected-text">@(Model.PartsOfSpeech.FirstOrDefault() ?? "Any")</span>
                            <i class="bi bi-chevron-down small opacity-50"></i>
                        </button>
                        <input type="hidden" id="posSelect" value="@Model.PartsOfSpeech.FirstOrDefault()">
                        <ul class="dropdown-menu w-100 shadow border-0 mt-1">
                            @foreach (var pos in Model.PartsOfSpeech)
                            {
                                <li><a class="dropdown-item @(pos == Model.PartsOfSpeech.FirstOrDefault() ? "active" : "")" href="#" data-value="@pos">@pos</a></li>
                            }
                        </ul>
                    </div>
                </div>

                <!-- Difficulty Level Dropdowns -->
                <div class="mb-4">
                    <label class="small fw-medium text-dark mb-2 ps-1">Difficulty Level</label>
                    <div class="d-flex gap-3">
                        <div class="flex-grow-1">
                            <div class="dropdown custom-dropdown" id="minDifficultyContainer">
                                <button class="btn btn-dropdown w-100 text-start d-flex justify-content-between align-items-center" 
                                        type="button" data-bs-toggle="dropdown" aria-expanded="false" id="minDifficultyBtn">
                                    <span class="selected-text">Min</span>
                                    <i class="bi bi-chevron-down small opacity-50"></i>
                                </button>
                                <input type="hidden" id="minDifficulty" value="">
                                <ul class="dropdown-menu w-100 shadow border-0 mt-1">
                                    <li><a class="dropdown-item active" href="#" data-value="">Min</a></li>
                                    @foreach (var level in Model.DifficultyLevels)
                                    {
                                        <li><a class="dropdown-item" href="#" data-value="@level">@level</a></li>
                                    }
                                </ul>
                            </div>
                        </div>
                        <div class="flex-grow-1">
                            <div class="dropdown custom-dropdown" id="maxDifficultyContainer">
                                <button class="btn btn-dropdown w-100 text-start d-flex justify-content-between align-items-center" 
                                        type="button" data-bs-toggle="dropdown" aria-expanded="false" id="maxDifficultyBtn">
                                    <span class="selected-text">Max</span>
                                    <i class="bi bi-chevron-down small opacity-50"></i>
                                </button>
                                <input type="hidden" id="maxDifficulty" value="">
                                <ul class="dropdown-menu w-100 shadow border-0 mt-1">
                                    <li><a class="dropdown-item active" href="#" data-value="">Max</a></li>
                                    @foreach (var level in Model.DifficultyLevels)
                                    {
                                        <li><a class="dropdown-item" href="#" data-value="@level">@level</a></li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="small fw-medium text-dark mb-2 ps-1">Words Count</label>
                    <div class="search-box">
                        <input type="number" id="wordCount" class="form-control border-0 bg-transparent px-3" 
                               value="5" min="1" max="50">
                    </div>
                </div>

                <div class="d-grid gap-3 pt-2">
                    <button type="button" id="btnAddRule" class="btn btn-action-outline-success">
                        <i class="bi bi-plus-lg me-2"></i>Add Rule
                    </button>
                    <button type="button" id="btnGenerate" class="btn btn-action-success">
                        <i class="bi bi-stars me-2"></i>Generate Bundle
                    </button>
                </div>
            </div>
        </div>

        <!-- Right Column: Queue -->
        <div class="col-lg-8 ps-lg-4">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="d-flex align-items-center">
                    <h5 class="fw-bold mb-0">Generation Queue</h5>
                    <span id="ruleCountBadge" class="badge bg-success ms-3 rounded-pill" style="display:none; font-size: 0.8rem; padding: 0.5em 0.8em;">0</span>
                </div>
            </div>
            
            <div id="ruleList" class="row g-4">
                <!-- Rules will be added here dynamically -->
                <div id="emptyRulesMessage" class="col-12 text-center py-5">
                    <div class="mb-3">
                        <i class="bi bi-clipboard-plus fs-1 text-muted opacity-25"></i>
                    </div>
                    <h6 class="text-dark fw-bold mb-1">Queue is empty</h6>
                    <p class="text-muted mb-0">Select criteria on the left and click "Add Rule" to populate your queue.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Generation Result Section -->
    <div id="resultContainer" class="mt-5" style="display:none;">
        <hr class="my-5 opacity-10">
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
            <div>
                <h4 class="fw-bold mb-1" id="resultTitle">Generation Result</h4>
                <p class="text-muted mb-0" id="resultDescription"></p>
            </div>
            <div class="d-flex gap-2">
                <form id="previewForm" action="/Bundle/PreviewGenerated" method="POST" target="_blank">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="previewTitle" name="Title" />
                    <input type="hidden" id="previewDescription" name="Description" />
                    <input type="hidden" id="previewWordsJson" name="WordsJson" />
                    <button type="submit" id="btnPreviewFull" class="btn btn-action-success">
                        <i class="bi bi-eye me-2"></i>Full Preview
                    </button>
                </form>
                <button class="btn btn-action-outline-success" onclick="document.getElementById('resultContainer').style.display='none'">
                    <i class="bi bi-x-lg me-2"></i>Close
                </button>
            </div>
        </div>
        
        <div class="row g-4" id="wordsResultList">
            <!-- Words will be rendered here -->
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Styles {
    <link rel="stylesheet" href="~/css/generator.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/generator.js" asp-append-version="true"></script>
}
