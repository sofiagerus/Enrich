@model Enrich.BLL.DTOs.BundleDTO

@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4 gap-3">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-3">
            <i class="bi bi-arrow-left"></i> Back
        </a>
        <h1 class="fw-semibold fs-4 mb-0">@Model.Title</h1>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@Model.Title">
                }
                <div class="card-body">
                    <p class="text-muted small mb-2">@Model.Description</p>
                    <div class="d-flex flex-wrap gap-1 mb-3">
                        @foreach (var level in Model.DifficultyLevels)
                        {
                            <span class="badge bg-light text-dark border">@level</span>
                        }
                    </div>
                    <div class="text-muted small">
                        <i class="bi bi-layers"></i> Words count: @Model.WordCount
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <h5 class="fw-bold mb-3">Words in this collection</h5>
            <div class="row g-3">
                @if (Model.Words != null && Model.Words.Any())
                {
                    @foreach (var word in Model.Words)
                    {
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm rounded-4 p-3 h-100" style="background: rgba(255,255,255,0.7);">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h6 class="fw-bold mb-1">@word.Term</h6>
                                    <span class="text-success small fw-medium">@word.PartOfSpeech</span>
                                </div>
                                <div class="text-muted small">@word.Translation</div>
                                @if (!string.IsNullOrEmpty(word.Example))
                                {
                                    <div class="mt-2 small fst-italic text-secondary">"@word.Example"</div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5 text-muted">
                        <i class="bi bi-chat-left-dots fs-1"></i>
                        <p class="mt-2">This collection is currently empty.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>