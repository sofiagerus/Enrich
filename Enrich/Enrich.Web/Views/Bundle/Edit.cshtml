@model Enrich.Web.ViewModels.EditBundleViewModel

@{
    ViewData["Title"] = "Edit Collection";
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/bundle-edit.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <a href="@Url.Action("Index")" class="btn btn-light rounded-circle me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="h3 mb-0 fw-bold">Edit Collection</h1>
    </div>

    <div class="card card-panel shadow-sm border-0 rounded-4">
        <!-- Status Information -->
        <div class="d-flex align-items-center gap-3 mb-4 p-3 rounded-4" style="background-color: #f0f4ff;">
            <p class="mb-0 fw-medium text-dark">Status:</p>
            <span class="status-badge-info status-@Model.Status.ToString().ToLower() px-3 py-1 rounded-pill small fw-semibold">
                @Model.Status
            </span>
        </div>

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger" role="alert">
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <form method="post" class="bundle-edit-form" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="row g-4">
                <!-- Left Column: Title, Description, Dropdowns -->
                <div class="col-lg-7">
                    <!-- Title Field -->
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label">Collection Title</label>
                        <input asp-for="Title" class="form-control w-100 rounded-4" placeholder="Your collection title">
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <!-- Description Field -->
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control w-100 rounded-4" placeholder="Describe the content and purpose of your collection"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                        <div class="mt-1">
                            <small class="text-muted" style="font-size: 0.75rem;">
                                <span id="description-count">0</span> / @Enrich.BLL.Constants.BundleConstants.DescriptionMaxLength characters
                            </small>
                        </div>
                    </div>

                    <!-- Categories -->
                    <div class="mb-4">
                        <label class="form-label">Categories</label>
                        <div class="dropdown custom-dropdown-container" id="categories-dropdown-container">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                <span class="selected-items-display text-muted">Select categories...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items" style="max-height: 300px; overflow-y: auto;">
                                    <!-- Populated by JS -->
                                </div>
                            </div>
                        </div>
                        <div id="category-ids-hidden"></div>
                    </div>

                    <!-- Words -->
                    <div class="mb-4">
                        <label class="form-label">Words</label>
                        <div class="dropdown custom-dropdown-container" id="words-dropdown-container">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                <span class="selected-items-display text-muted">Select words...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items" style="max-height: 300px; overflow-y: auto;">
                                    <!-- Populated by JS -->
                                </div>
                            </div>
                        </div>
                        <div id="word-ids-hidden"></div>
                    </div>

                    <!-- Levels -->
                    <div class="mb-0">
                        <label class="form-label">Difficulty Levels</label>
                        <div class="dropdown custom-dropdown-container" id="levels-dropdown-container">
                            <button class="btn-dropdown rounded-4" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                <span class="selected-items-display text-muted">Select levels...</span>
                                <i class="bi bi-chevron-down opacity-50 small"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-custom shadow rounded-4">
                                <div class="dropdown-list-items" style="max-height: 250px; overflow-y: auto;">
                                    <!-- Populated by JS -->
                                </div>
                            </div>
                        </div>
                        <div id="level-ids-hidden"></div>
                    </div>
                </div>

                <!-- Right Column: Image -->
                <div class="col-lg-5">
                    <label class="form-label">Cover Image</label>
                    <div class="image-upload-box w-100 rounded-4" id="image-upload-box" onclick="document.getElementById('file-input').click()">
                        <div id="upload-placeholder" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "" : "display: none;")">
                            <i class="bi bi-folder" style="font-size: 2.5rem; color: var(--enrich-text-muted);"></i>
                            <p class="text-muted mb-3 fw-medium mt-2">Click to upload cover image</p>
                            <button type="button" class="image-upload-btn rounded-4">Upload Image</button>
                        </div>
                        <div id="image-preview-container" style="@(!string.IsNullOrEmpty(Model.ImageUrl) ? "display: block; width: 100%; height: 100%;" : "display: none; width: 100%; height: 100%;")">
                            <img id="image-preview" src="@Model.ImageUrl" class="image-preview rounded-4" alt="Preview">
                        </div>
                    </div>
                    <div id="change-image-btn-container" class="mt-3 text-center" style="@(!string.IsNullOrEmpty(Model.ImageUrl) ? "display: block;" : "display: none;")">
                        <button type="button" class="btn-change-image" onclick="document.getElementById('file-input').click()">
                            <i class="bi bi-pencil me-2"></i> Change Image
                        </button>
                    </div>
                    <input type="file" id="file-input" style="display:none;" accept="image/*">
                    <input type="hidden" asp-for="ImageUrl" id="ImageUrl">
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-center mt-5 pt-4 border-top">
                <button type="submit" class="btn-action-success rounded-4">
                    <i class="bi bi-save me-2"></i> Save Changes
                </button>
                <a href="@Url.Action("Index")" class="btn-action-outline-success rounded-4">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/bundle-edit.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            BundleEdit.init({
                selectedCategoryIds: @Html.Raw(Json.Serialize(Model.CategoryIds ?? new List<int>())),
                selectedWordIds: @Html.Raw(Json.Serialize(Model.WordIds ?? new List<int>())),
                selectedLevels: @Html.Raw(Json.Serialize(Model.DifficultyLevels ?? new List<string>())),
                allWords: @Html.Raw(Json.Serialize(Model.Words ?? new List<Enrich.Web.ViewModels.WordItemViewModel>())),
                availableLevels: @Html.Raw(Json.Serialize(Model.AvailableLevels ?? new List<string>()))
            });
        });
    </script>
}
