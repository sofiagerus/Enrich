@model Enrich.Web.ViewModels.StudySessionViewModel

@{
    ViewData["Title"] = "Study Session - " + Model.BundleTitle;
    Layout = "~/Views/Shared/_AppLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/study.min.css" asp-append-version="true" />
}

<div class="study-page-wrapper">

    @* --- STUDY INTERFACE --- *@
    <div id="studyInterface">
        <div class="study-nav-header">
            <div class="progress-counter" id="cardCounter">1/@Model.TotalCards</div>
        </div>

        @Html.AntiForgeryToken()

        <div class="flashcard-scene" onclick="toggleCard()">
            <div class="flashcard-inner" id="cardInner">
                <div class="card-face card-face-front">
                    <h1 class="term-display" id="cardTerm"></h1>
                    <div class="transcription-display" id="cardTranscription"></div>
                    <div class="mt-5 text-muted opacity-50 small">
                        <i class="bi bi-arrow-repeat me-2"></i> Tap to flip
                    </div>
                </div>
                <div class="card-face card-face-back">
                    <h1 class="translation-display" id="cardTranslation"></h1>
                    <p id="cardExample" class="example-display"></p>
                </div>
            </div>
        </div>

        <div class="study-controls">
            <button class="btn-app-action" onclick="addToMyWords()">
                <i class="bi bi-plus-circle"></i> Add to My Words
            </button>
            <button class="btn-app-action" onclick="handleAnswer(false)">
                <i class="bi bi-x-circle"></i> Don't Know
            </button>
            <button class="btn-app-action btn-know" onclick="handleAnswer(true)">
                <i class="bi bi-check-circle"></i> Know This
            </button>
        </div>
    </div>

    @* --- RESULTS SCREEN --- *@
    <div id="resultsScreen" style="display: none; text-align: center;">
        <div class="mb-4">
            <i class="bi bi-star-fill text-warning" style="font-size: 4rem;"></i>
        </div>

        <h1 class="display-5 fw-bold mb-2">Session Finished!</h1>

        <div class="result-circle">
            <span id="finalPoints" style="line-height: 1;">0</span>
            <span style="font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; margin-top: 5px;">points</span>
        </div>

        <p class="fs-5 text-secondary mb-5">
            You've mastered <b class="text-dark" id="knownCount">0</b> out of @Model.TotalCards words!
        </p>

        <div class="d-flex gap-3 justify-content-center">
            <a asp-action="Study" asp-route-bundleId="@Model.BundleId" class="btn-app-action text-decoration-none">
                <i class="bi bi-arrow-counterclockwise"></i> Restart
            </a>
            <a asp-action="Index" class="btn-app-action btn-know text-decoration-none">
                Return to Dashboard
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const cards = @Html.Raw(Json.Serialize(Model.Cards));
        const total = @Model.TotalCards;
        const sessionId = @Model.SessionId;

        let currentIdx = 0;
        let knownCount = 0;
        let totalPoints = 0;

        function updateUI() {
            if (currentIdx >= total) return;
            const card = cards[currentIdx];
            document.getElementById('cardTerm').innerText = card.term || card.Term || "";
            document.getElementById('cardTranscription').innerText = (card.transcription || card.Transcription) ? `[${card.transcription || card.Transcription}]` : "";
            document.getElementById('cardTranslation').innerText = card.translation || card.Translation || "";
            document.getElementById('cardCounter').innerText = `${currentIdx + 1}/${total}`;
            const ex = card.example || card.Example;
            document.getElementById('cardExample').innerText = ex ? `"${ex}"` : "";
        }

        function toggleCard() {
            document.getElementById('cardInner').classList.toggle('is-flipped');
        }

        async function addToMyWords() {
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            try {
                await fetch('/Words/AddToMyWords', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({ wordId: cards[currentIdx].wordId || cards[currentIdx].WordId })
                });
            } catch (e) {
                console.error("Error adding word:", e);
            }
        }

        async function handleAnswer(isKnown) {
            document.getElementById('cardInner').classList.remove('is-flipped');
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            try {
                const response = await fetch('/Bundle/SubmitAnswer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': token },
                    body: JSON.stringify({
                        sessionId: sessionId,
                        wordId: cards[currentIdx].wordId || cards[currentIdx].WordId,
                        isKnown: isKnown
                    })
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result && result.totalPoints !== undefined) {
                        totalPoints = result.totalPoints;
                    }
                }
            } catch (e) {
                console.error("Error saving progress:", e);
            }

            if (isKnown) knownCount++;
            currentIdx++;

            if (currentIdx < total) {
                setTimeout(updateUI, 200);
            } else {
                showResults();
            }
        }

        function showResults() {
            document.getElementById('studyInterface').style.display = 'none';
            document.getElementById('resultsScreen').style.display = 'block';
            document.getElementById('knownCount').innerText = knownCount;
            document.getElementById('finalPoints').innerText = totalPoints;
        }

        document.addEventListener('DOMContentLoaded', updateUI);
    </script>
}
